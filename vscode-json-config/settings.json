{
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
        },
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
        },
      },
      "enable_lsp_tasks": true,
    },
  },
  "icon_theme": "JetBrains New UI Icons (Light)",
  "theme": "Zedokai Classic",
  "title_bar": {
    "show_onboarding_banner": false,
    "show_project_items": false,
    "show_branch_name": false,
    "show_user_menu": false,
  },
  "tab_bar": {
    "show": true,
    "show_nav_history_buttons": false,
    "show_tab_bar_buttons": false,
    "show_pinned_tabs_in_separate_row": false,
  },
  "toolbar": {
    "quick_actions": false,
    "breadcrumbs": false,
  },
  "status_bar": {
    "experimental.show": false,
  },
  "project_panel": {
    "dock": "right",
    "default_width": 400,
    "hide_root": true,
    "auto_fold_dirs": false,
    "starts_open": false,
    "git_status": false,
    "sticky_scroll": true,
    "entry_spacing": "standard",
    "hide_hidden": false,
    "indent_size": 15,

    "scrollbar": {
      "show": "never",
    },
    "indent_guides": {
      "show": "never",
    },
  },
  "outline_panel": {
    "default_width": 300,
    "indent_guides": {
      "show": "never",
    },
  },
  "file_finder": {
    "modal_max_width": "large",
    "file_icons": true,
  },

  "terminal": {
    "font_size": 20,
  },
  "scrollbar": {
    "show": "never",
  },
  "gutter": {
    "min_line_number_digits": 0,
    "folds": false,
    "runnables": false,
  },
  "indent_guides": {
    "enabled": false,
  },
  "ui_font_family": "Iosevka",
  "ui_font_size": 25,
  "cursor_blink": false,

  "disable_ai": true,
  "buffer_font_family": "JetBrains Mono",
  "buffer_font_size": 24,
  "buffer_line_height": {
    "custom": 1.25,
  },
  "agent_buffer_font_size": 20,
  "drag_and_drop_selection": {
    "enabled": false,
  },

  "seed_search_query_from_cursor": "never",
  "current_line_highlight": "gutter",
  "show_whitespaces": "none",
  "tab_size": 2,
  "auto_indent": false,
  "auto_indent_on_paste": false,
  "show_completions_on_input": true,
  "show_completion_documentation": false,
  "inline_code_actions": false,
  "lsp_document_colors": "none",
  "hover_popover_enabled": true,
  "format_on_save": "on",
  "auto_update": false,
  "extend_comment_on_newline": false,
  "horizontal_scroll_margin": 1,
  "vertical_scroll_margin": 1,
  "when_closing_with_no_tabs": "close_window",
  "close_on_file_delete": true,
  "restore_on_file_reopen": false,
  "restore_on_startup": "launchpad",
  "session": {
    "trust_all_worktrees": true,
    "restore_unsaved_buffers": false,
  },
  "git": {
    "git_gutter": "hide",
    "inline_blame": {
      "enabled": true,
    },
  },
  "centered_layout": {
    "right_padding": 0.15,
    "left_padding": 0.15,
  },
}
